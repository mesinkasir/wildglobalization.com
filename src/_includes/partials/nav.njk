    </svg>
    <span>{{ navigation.button.label }}</span>
  </a>
  
  <a class="button button--small button--journey site-header__cta" href="{{ navigation.graduation.href }}" rel="noopener noreferrer" target="_blank">
    <svg class="button__icon" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256" aria-hidden="true" focusable="false">
      <path d="M251.76,88.94l-120-64a8,8,0,0,0-7.52,0l-120,64a8,8,0,0,0,0,14.12L32,117.87v48.42a15.91,15.91,0,0,0,4.06,10.65C49.16,191.53,78.51,216,128,216a130,130,0,0,0,48-8.76V240a8,8,0,0,0,16,0V199.51a115.63,115.63,0,0,0,27.94-22.57A15.91,15.91,0,0,0,224,166.29V117.87l27.76-14.81a8,8,0,0,0,0-14.12ZM128,200c-43.27,0-68.72-21.14-80-33.71V126.4l76.24,40.66a8,8,0,0,0,7.52,0L176,143.47v46.34C163.4,195.69,147.52,200,128,200Zm80-33.75a97.83,97.83,0,0,1-16,14.25V134.93l16-8.53ZM188,118.94l-.22-.13-56-29.87a8,8,0,0,0-7.52,14.12L171,128l-43,22.93L25,96,128,41.07,231,96Z"></path>
    </svg>
    <span>{{ navigation.graduation.label }}</span>
  </a>
  
  <a class="button button--small button--learn site-header__cta" href="https://journey.wildglobalization.com/products/courses/wild-globalization-pilot" rel="noopener noreferrer" target="_blank">
    <svg class="button__icon" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 256 256" aria-hidden="true" focusable="false">
      <path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm0,192a88,88,0,1,1,88-88A88.1,88.1,0,0,1,128,216ZM120,72v56a8,8,0,0,0,4.42,7.16l40,24a8,8,0,0,0,11.16-2.42,8,8,0,0,0-2.42-11.16L136,123.6V72a8,8,0,0,0-16,0Z"></path>
