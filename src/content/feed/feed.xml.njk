---
permalink: /feed/feed.xml
---
<?xml version="1.0" encoding="utf-8"?>
<?xml-stylesheet type="text/xsl" href="/feed/pretty-atom-feed.xsl"?>
<feed xmlns="http://www.w3.org/2005/Atom">
	<title>{{ settings.title }}</title>
	<subtitle>{{ settings.description }}</subtitle>
	<id>{{ '/' | fullUrl }}</id>
	<link href="{{ '/feed/feed.xml' | fullUrl }}" rel="self" />
	<link href="{{ '/' | fullUrl }}" />
	<link href="{{ '/feed/firehose.xml' | fullUrl }}" rel="related" type="application/atom+xml" title="{{ settings.title }} Firehose" />
	<link href="https://explore.wildglobalization.com/feed" rel="related" type="application/atom+xml" title="Wild Globalization Explore Feed" />
	{% if collections.blog[0] %}
	<updated>{{ collections.blog[0].date | dateToRfc3339 }}</updated>
	{% endif %}
	<author>
		<name>{{ settings.author.name }}</name>
		<uri>{{ settings.author.url }}</uri>
	</author>

	{% for post in collections.blog | limit(20) %}
	<entry>
		<title>{{ post.data.title }}</title>
		<id>{{ post.url | fullUrl }}</id>
		<link href="{{ post.url | fullUrl }}" />
		<updated>{{ post.date | dateToRfc3339 }}</updated>
		<summary>{{ post.templateContent | excerpt }}</summary>
		<content type="html"><![CDATA[{{ (post.templateContent or post.content or post.data.description or '') | trim | replace(']]>', ']]]]><![CDATA[>') | safe }}]]></content>
	</entry>
	{% endfor %}
</feed>
